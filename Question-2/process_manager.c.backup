/*
 * Process Manager - Web Server Child Process Monitor
 * 
 * Purpose: Demonstrates process creation, monitoring, zombie prevention,
 *          and signal handling to manage child processes effectively.
 * 
 * Author: manjitms173
 * Date: July 20, 2026
 */

#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <signal.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <time.h>
#include <string.h>
#include <errno.h>

#define MAX_CHILDREN 5
#define TIMEOUT_SECONDS 5
#define COLOR_GREEN   "\x1b[32m"
#define COLOR_RED     "\x1b[31m"
#define COLOR_YELLOW  "\x1b[33m"
#define COLOR_BLUE    "\x1b[34m"
#define COLOR_RESET   "\x1b[0m"

// Structure to track child processes
typedef struct {
    pid_t pid;
    time_t start_time;
    int is_responsive;
    int exit_status;
} ChildProcess;

ChildProcess children[MAX_CHILDREN];
int active_children = 0;
volatile sig_atomic_t child_exited = 0;

// Function prototypes
void sigchld_handler(int sig);
void setup_signal_handlers(void);
void create_child_process(int child_id);
void monitor_children(void);
void terminate_unresponsive_children(void);
void cleanup_zombies(void);
void print_status(const char* message, const char* color);
void simulate_child_work(int child_id);

/*
 * SIGCHLD Signal Handler
 * Called when a child process terminates
 * Prevents zombie processes by reaping children
 */
void sigchld_handler(int sig) {
    (void)sig; // Unused parameter
    child_exited = 1;
}

/*
 * Setup Signal Handlers
 * Configures SIGCHLD to handle child termination
 */
void setup_signal_handlers(void) {
    struct sigaction sa;
    
    // Setup SIGCHLD handler
    memset(&sa, 0, sizeof(sa));
    sa.sa_handler = sigchld_handler;
    sigemptyset(&sa.sa_mask);
    sa.sa_flags = SA_RESTART | SA_NOCLDSTOP;
    
    if (sigaction(SIGCHLD, &sa, NULL) == -1) {
        perror("sigaction");
        exit(EXIT_FAILURE);
    }
    
    print_status("✓ Signal handlers configured", COLOR_GREEN);
}

/*
 * Print Colored Status Messages
 */
void print_status(const char* message, const char* color) {
    printf("%s[%ld] %s%s\n", color, (long)getpid(), message, COLOR_RESET);
    fflush(stdout);
}

/*
 * Simulate Child Work
 * Some children are responsive, others are unresponsive (long sleep)
 */
void simulate_child_work(int child_id) {
    // Child 2 and 4 will be unresponsive (simulate hanging)
    if (child_id == 2 || child_id == 4) {
        printf("%s[Child %d - PID %d] Simulating UNRESPONSIVE process (sleeping 30s)%s\n",
               COLOR_RED, child_id, getpid(), COLOR_RESET);
        sleep(30); // Hang for 30 seconds
    } else {
        // Normal responsive child
        int work_time = 1 + (rand() % 3); // 1-3 seconds
        printf("%s[Child %d - PID %d] Processing request (%d seconds)%s\n",
               COLOR_GREEN, child_id, getpid(), work_time, COLOR_RESET);
        sleep(work_time);
        printf("%s[Child %d - PID %d] Request completed successfully%s\n",
               COLOR_GREEN, child_id, getpid(), COLOR_RESET);
    }
}

/*
 * Create Child Process
 * Forks a new child and initializes tracking structure
 */
void create_child_process(int child_id) {
    pid_t pid = fork();
    
    if (pid < 0) {
        perror("fork");
        exit(EXIT_FAILURE);
    }
    
    if (pid == 0) {
        // Child process code
        srand(time(NULL) ^ getpid());
        printf("%s[Child %d - PID %d] Started%s\n",
               COLOR_BLUE, child_id, getpid(), COLOR_RESET);
        
        simulate_child_work(child_id);
        
        // Exit with success status
        exit(EXIT_SUCCESS);
    } else {
        // Parent process code
        children[active_children].pid = pid;
        children[active_children].start_time = time(NULL);
        children[active_children].is_responsive = 1;
        children[active_children].exit_status = -1;
        
        printf("%s[Parent] Created child %d with PID %d%s\n",
               COLOR_YELLOW, child_id, pid, COLOR_RESET);
        
        active_children++;
    }
}

/*
 * Cleanup Zombie Processes
 * Reaps terminated children to prevent zombies
 */
void cleanup_zombies(void) {
    pid_t pid;
    int status;
    
    // Non-blocking wait for any terminated child
    while ((pid = waitpid(-1, &status, WNOHANG)) > 0) {
        // Find the child in our tracking array
        for (int i = 0; i < active_children; i++) {
            if (children[i].pid == pid) {
                if (WIFEXITED(status)) {
                    children[i].exit_status = WEXITSTATUS(status);
                    printf("%s[Parent] Child PID %d exited normally (status: %d)%s\n",
                           COLOR_GREEN, pid, children[i].exit_status, COLOR_RESET);
                } else if (WIFSIGNALED(status)) {
                    printf("%s[Parent] Child PID %d terminated by signal %d%s\n",
                           COLOR_RED, pid, WTERMSIG(status), COLOR_RESET);
                }
                children[i].is_responsive = 0;
                break;
            }
        }
    }
    
    child_exited = 0;
}

/*
 * Terminate Unresponsive Children
 * Detects children exceeding timeout and terminates them
 */
void terminate_unresponsive_children(void) {
    time_t current_time = time(NULL);
    
    for (int i = 0; i < active_children; i++) {
        if (children[i].is_responsive && children[i].exit_status == -1) {
            time_t elapsed = current_time - children[i].start_time;
            
            if (elapsed > TIMEOUT_SECONDS) {
                printf("%s[Parent] Child PID %d unresponsive (timeout: %ld seconds)%s\n",
                       COLOR_RED, children[i].pid, elapsed, COLOR_RESET);
                
                // Try graceful termination first (SIGTERM)
                printf("%s[Parent] Sending SIGTERM to PID %d%s\n",
                       COLOR_YELLOW, children[i].pid, COLOR_RESET);
                
                if (kill(children[i].pid, SIGTERM) == -1) {
                    perror("kill SIGTERM");
                }
                
                // Wait 2 seconds for graceful shutdown
                sleep(2);
                
                // Check if process still exists
                if (kill(children[i].pid, 0) == 0) {
                    // Process still running, force kill
                    printf("%s[Parent] Child PID %d still running, sending SIGKILL%s\n",
                           COLOR_RED, children[i].pid, COLOR_RESET);
                    
                    if (kill(children[i].pid, SIGKILL) == -1) {
                        perror("kill SIGKILL");
                    }
                }
            }
        }
    }
}

/*
 * Monitor Children
 * Main monitoring loop
 */
void monitor_children(void) {
    int all_done = 0;
    
    while (!all_done) {
        // Check for terminated children
        if (child_exited) {
            cleanup_zombies();
        }
        
        // Check for unresponsive children
        terminate_unresponsive_children();
        
        // Check if all children have finished
        all_done = 1;
        for (int i = 0; i < active_children; i++) {
            if (children[i].exit_status == -1) {
                all_done = 0;
                break;
            }
        }
        
        sleep(1); // Monitor every second
    }
    
    print_status("✓ All children have been processed", COLOR_GREEN);
}

/*
 * Main Function
 */
int main(void) {
    printf("\n%s========================================%s\n", COLOR_BLUE, COLOR_RESET);
    printf("%s  Web Server Process Manager Demo  %s\n", COLOR_BLUE, COLOR_RESET);
    printf("%s========================================%s\n\n", COLOR_BLUE, COLOR_RESET);
    
    // Initialize
    memset(children, 0, sizeof(children));
    srand(time(NULL));
    
    // Setup signal handling
    setup_signal_handlers();
    
    // Create child processes
    printf("\n%s--- Creating Child Processes ---%s\n\n", COLOR_YELLOW, COLOR_RESET);
    for (int i = 0; i < MAX_CHILDREN; i++) {
        create_child_process(i);
        usleep(100000); // 100ms delay between forks
    }
    
    printf("\n%s--- Monitoring Children ---%s\n\n", COLOR_YELLOW, COLOR_RESET);
    printf("[Parent] Timeout threshold: %d seconds\n\n", TIMEOUT_SECONDS);
    
    // Monitor and manage children
    monitor_children();
    
    // Final cleanup
    printf("\n%s--- Final Cleanup ---%s\n\n", COLOR_YELLOW, COLOR_RESET);
    cleanup_zombies();
    
    // Print summary
    printf("\n%s========================================%s\n", COLOR_BLUE, COLOR_RESET);
    printf("%s           Summary Report            %s\n", COLOR_BLUE, COLOR_RESET);
    printf("%s========================================%s\n\n", COLOR_BLUE, COLOR_RESET);
    
    for (int i = 0; i < active_children; i++) {
        printf("Child %d (PID %d): ", i, children[i].pid);
        if (children[i].exit_status == 0) {
            printf("%sCompleted Successfully%s\n", COLOR_GREEN, COLOR_RESET);
        } else {
            printf("%sTerminated (unresponsive)%s\n", COLOR_RED, COLOR_RESET);
        }
    }
    
    printf("\n%sProgram completed successfully!%s\n\n", COLOR_GREEN, COLOR_RESET);
    
    return EXIT_SUCCESS;
}
